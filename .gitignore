# ==========================================
# SplitSense - Unified Root .gitignore
# ==========================================

# 1. Dependencies (Catches both frontend and backend)
node_modules/
jspm_packages/
.npm/

# 2. Environment Variables & Secrets (CRITICAL)
# The ** ensures it catches .env files in any subfolder
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
*.pem

# 3. Frontend Build Outputs (Vite/React)
frontend/dist/
frontend/build/
frontend/out/
*.tsbuildinfo

# 4. Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 6. IDEs and Editors
.vscode/
.idea/
.vs/
*.suo
*.swp
*.swo

# 7. Misc
.eslintcache
coverage/